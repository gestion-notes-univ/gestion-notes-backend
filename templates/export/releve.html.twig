<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Relevé de notes</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 12px; color: #2c2c2a; background: #fff; }

        .header { display: table; width: 100%; border-bottom: 2px solid #3C3489; padding-bottom: 12px; margin-bottom: 20px; }
        .header-left  { display: table-cell; vertical-align: middle; width: 70%; }
        .header-right { display: table-cell; vertical-align: middle; text-align: right; width: 30%; }
        .univ-name { font-size: 15px; font-weight: bold; color: #3C3489; text-transform: uppercase; letter-spacing: 1px; }
        .univ-sub  { font-size: 11px; color: #5F5E5A; margin-top: 2px; }
        .doc-title { font-size: 18px; font-weight: bold; color: #3C3489; text-transform: uppercase; }
        .doc-sub   { font-size: 10px; color: #888780; margin-top: 2px; }

        .info-box  { background: #EEEDFE; border-left: 4px solid #3C3489; border-radius: 4px; padding: 10px 14px; margin-bottom: 18px; }
        .info-grid { display: table; width: 100%; }
        .info-col  { display: table-cell; width: 50%; vertical-align: top; }
        .info-row  { margin-bottom: 4px; }
        .info-label { font-size: 10px; color: #534AB7; text-transform: uppercase; letter-spacing: 0.5px; }
        .info-value { font-size: 12px; font-weight: bold; color: #26215C; }

        .section-title { font-size: 11px; font-weight: bold; color: #534AB7; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; border-bottom: 1px solid #AFA9EC; padding-bottom: 4px; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
        thead tr { background: #3C3489; color: #fff; }
        thead th { padding: 8px 10px; text-align: left; font-size: 10px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.3px; }
        thead th.center { text-align: center; }
        tbody tr:nth-child(even) { background: #F1EFE8; }
        tbody tr:nth-child(odd)  { background: #fff; }
        tbody td { padding: 7px 10px; font-size: 11px; border-bottom: 0.5px solid #D3D1C7; color: #2c2c2a; }
        tbody td.center { text-align: center; }

        .note-admis     { color: #27500A; font-weight: bold; }
        .note-non-admis { color: #712B13; font-weight: bold; }
        .badge-admis     { background: #EAF3DE; color: #27500A; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: bold; }
        .badge-non-admis { background: #FAECE7; color: #712B13; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: bold; }

        .recap      { display: table; width: 100%; margin-bottom: 18px; border-spacing: 8px; }
        .recap-card { display: table-cell; background: #F1EFE8; border-radius: 6px; border: 1px solid #D3D1C7; padding: 10px 14px; text-align: center; width: 25%; }
        .recap-label { font-size: 10px; color: #5F5E5A; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 4px; }
        .recap-value { font-size: 20px; font-weight: bold; color: #3C3489; }
        .recap-value.success { color: #27500A; }
        .recap-value.danger  { color: #712B13; }

        .delib-box       { border-radius: 6px; padding: 12px 16px; margin-bottom: 18px; display: table; width: 100%; }
        .delib-admis     { background: #EAF3DE; border: 1px solid #639922; }
        .delib-ajourne   { background: #FAECE7; border: 1px solid #D85A30; }
        .delib-rattrapage{ background: #FAEEDA; border: 1px solid #BA7517; }
        .delib-left  { display: table-cell; vertical-align: middle; width: 70%; }
        .delib-right { display: table-cell; vertical-align: middle; text-align: right; }
        .delib-title { font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px; }
        .delib-admis     .delib-title { color: #3B6D11; }
        .delib-ajourne   .delib-title { color: #712B13; }
        .delib-rattrapage .delib-title { color: #633806; }
        .delib-decision { font-size: 16px; font-weight: bold; text-transform: uppercase; }
        .delib-admis     .delib-decision { color: #173404; }
        .delib-ajourne   .delib-decision { color: #4A1B0C; }
        .delib-rattrapage .delib-decision { color: #412402; }

        .footer       { border-top: 1px solid #D3D1C7; padding-top: 10px; margin-top: 20px; display: table; width: 100%; }
        .footer-left  { display: table-cell; font-size: 10px; color: #888780; }
        .footer-right { display: table-cell; text-align: right; font-size: 10px; color: #888780; }

        .signature-zone { margin-top: 30px; display: table; width: 100%; }
        .signature-col  { display: table-cell; width: 33%; text-align: center; }
        .signature-line { border-top: 1px solid #888780; margin: 40px 20px 6px; }
        .signature-label { font-size: 10px; color: #5F5E5A; }
    </style>
</head>
<body>

    {# ---- EN-TÊTE ---- #}
    <div class="header">
        <div class="header-left">
            <div class="univ-name">Université — Établissement</div>
            <div class="univ-sub">Service de la Scolarité</div>
        </div>
        <div class="header-right">
            <div class="doc-title">Relevé de notes</div>
            <div class="doc-sub">Document officiel</div>
        </div>
    </div>

    {# ---- INFOS ÉTUDIANT ---- #}
    {# etudiant.utilisateur → getUtilisateur() → getNom() / getPrenom() #}
    <div class="info-box">
        <div class="info-grid">
            <div class="info-col">
                <div class="info-row">
                    <div class="info-label">Nom complet</div>
                    <div class="info-value">{{ etudiant.utilisateur.nom }} {{ etudiant.utilisateur.prenom }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Numéro étudiant</div>
                    {# etudiant.numeroEtudiant → getNumeroEtudiant() #}
                    <div class="info-value">{{ etudiant.numeroEtudiant }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Filière</div>
                    {# etudiant.filiere → getFiliere() → getNom() #}
                    <div class="info-value">{{ etudiant.filiere.nom }}</div>
                </div>
            </div>
            <div class="info-col">
                <div class="info-row">
                    <div class="info-label">Semestre</div>
                    <div class="info-value">{{ semestre.nom }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Année académique</div>
                    {# semestre.anneeAcademique → getAnneeAcademique() #}
                    <div class="info-value">{{ semestre.anneeAcademique }}</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Date d'édition</div>
                    <div class="info-value">{{ date_export|date('d/m/Y') }}</div>
                </div>
            </div>
        </div>
    </div>

    {# ---- TABLEAU DES NOTES ---- #}
    {# note.ue → getUe() (propriété $ue dans Note.php — pas uniteEnseignement) #}
    {# note.noteCc → getNoteCc() #}
    {# note.noteExamen → getNoteExamen() #}
    {# note.noteFinale → getNoteFinale() (GENERATED par PostgreSQL) #}
    <div class="section-title">Détail des notes par unité d'enseignement</div>
    <table>
        <thead>
            <tr>
                <th>Code</th>
                <th>Unité d'enseignement</th>
                <th class="center">Coefficient</th>
                <th class="center">Crédits ECTS</th>
                <th class="center">Note CC /20</th>
                <th class="center">Note Examen /20</th>
                <th class="center">Note Finale /20</th>
                <th class="center">Résultat</th>
            </tr>
        </thead>
        <tbody>
            {% for note in notes %}
            <tr>
                {# note.ue.code → getUe()->getCode() #}
                <td><strong>{{ note.ue.code }}</strong></td>
                {# note.ue.nom → getUe()->getNom() #}
                <td>{{ note.ue.nom }}</td>
                {# note.ue.coefficient → getUe()->getCoefficient() #}
                <td class="center">{{ note.ue.coefficient }}</td>
                {# note.ue.creditsEcts → getUe()->getCreditsEcts() #}
                <td class="center">{{ note.ue.creditsEcts }}</td>
                {# note.noteCc → getNoteCc() #}
                <td class="center">
                    {{ note.noteCc is not null ? note.noteCc|number_format(2, ',', ' ') : '—' }}
                </td>
                {# note.noteExamen → getNoteExamen() #}
                <td class="center">
                    {{ note.noteExamen is not null ? note.noteExamen|number_format(2, ',', ' ') : '—' }}
                </td>
                {# note.noteFinale → getNoteFinale() calculé par PostgreSQL GENERATED #}
                <td class="center {{ note.noteFinale is not null and note.noteFinale >= note.ue.noteMinimum ? 'note-admis' : 'note-non-admis' }}">
                    {{ note.noteFinale is not null ? note.noteFinale|number_format(2, ',', ' ') : '—' }}
                </td>
                <td class="center">
                    {% if note.noteFinale is not null and note.noteFinale >= note.ue.noteMinimum %}
                        <span class="badge-admis">Validé</span>
                    {% else %}
                        <span class="badge-non-admis">Non validé</span>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8" class="center" style="color: #888780; font-style: italic; padding: 16px;">
                    Aucune note disponible pour ce semestre.
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ---- RÉCAPITULATIF ---- #}
    {% if notes|length > 0 %}
    <div class="section-title">Récapitulatif</div>
    <div class="recap">
        <div class="recap-card">
            <div class="recap-label">Moyenne générale</div>
            <div class="recap-value {{ moyenne is not null and moyenne >= 10 ? 'success' : 'danger' }}">
                {{ moyenne is not null ? moyenne|number_format(2, ',', ' ') : '—' }}
            </div>
        </div>
        <div class="recap-card">
            <div class="recap-label">UE validées</div>
            <div class="recap-value success">
                {# note.noteFinale >= note.ue.noteMinimum → utilise noteMinimum de l'UE #}
                {{ notes|filter(n => n.noteFinale is not null and n.noteFinale >= n.ue.noteMinimum)|length }}
                / {{ notes|length }}
            </div>
        </div>
        <div class="recap-card">
            <div class="recap-label">Crédits obtenus</div>
            <div class="recap-value">
                {% set credits = 0 %}
                {% for note in notes %}
                    {% if note.noteFinale is not null and note.noteFinale >= note.ue.noteMinimum %}
                        {# note.ue.creditsEcts → getUe()->getCreditsEcts() #}
                        {% set credits = credits + note.ue.creditsEcts %}
                    {% endif %}
                {% endfor %}
                {{ credits }}
            </div>
        </div>
        <div class="recap-card">
            <div class="recap-label">Taux de réussite</div>
            <div class="recap-value">
                {% set nb_admis = notes|filter(n => n.noteFinale is not null and n.noteFinale >= n.ue.noteMinimum)|length %}
                {{ notes|length > 0 ? ((nb_admis / notes|length) * 100)|round : 0 }}%
            </div>
        </div>
    </div>
    {% endif %}

    {# ---- DÉLIBÉRATION ---- #}
    {# deliberation.decision → getDecision() ENUM : admis | ajourne | rattrapage | exclus #}
    {# deliberation.moyenneGenerale → getMoyenneGenerale() #}
    {# deliberation.creditsValides → getCreditsValides() #}
    {# deliberation.dateDeliberation → getDateDeliberation() #}
    {% if deliberation %}
    <div class="section-title">Résultat de délibération</div>
    <div class="delib-box delib-{{ deliberation.decision }}">
        <div class="delib-left">
            <div class="delib-title">Décision du jury</div>
            <div style="font-size: 11px; margin-top: 2px;">
                Délibéré le {{ deliberation.dateDeliberation|date('d/m/Y') }}
                — Crédits validés : {{ deliberation.creditsValides }}
            </div>
        </div>
        <div class="delib-right">
            <div class="delib-decision">
                {% if deliberation.decision == 'admis' %}
                    ✓ Admis(e)
                {% elseif deliberation.decision == 'rattrapage' %}
                    ⚠ Rattrapage
                {% elseif deliberation.decision == 'ajourne' %}
                    ✗ Ajourné(e)
                {% else %}
                    {{ deliberation.decision|upper }}
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ---- SIGNATURES ---- #}
    <div class="signature-zone">
        <div class="signature-col">
            <div class="signature-line"></div>
            <div class="signature-label">Le/La Responsable pédagogique</div>
        </div>
        <div class="signature-col">
            <div class="signature-line"></div>
            <div class="signature-label">Le/La Chef(fe) de département</div>
        </div>
        <div class="signature-col">
            <div class="signature-line"></div>
            <div class="signature-label">Le/La Directeur(trice)</div>
        </div>
    </div>

    {# ---- PIED DE PAGE ---- #}
    <div class="footer">
        <div class="footer-left">
            Document généré automatiquement le {{ date_export|date('d/m/Y à H:i') }}
            — Ce document est officiel et confidentiel.
        </div>
        <div class="footer-right">
            {{ etudiant.numeroEtudiant }} — {{ semestre.anneeAcademique }}
        </div>
    </div>

</body>
</html>
